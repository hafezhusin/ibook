# Normalise line endings to LF for all text files
* text=auto eol=lf

# PHP, Blade, config — always LF
*.php     text eol=lf
*.blade.php text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.xml     text eol=lf
*.env     text eol=lf
*.md      text eol=lf
*.sh      text eol=lf
*.txt     text eol=lf
*.neon    text eol=lf

# Binary — no conversion
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.zip     binary
*.gz      binary
